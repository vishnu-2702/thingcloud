                      <div className="text-3xl font-bold text-gray-900">48</div>
                      <div className="text-xs text-gray-600 font-medium">Online Devices</div>
                    </div>
                    <div className="dashboard-stat bg-gradient-to-br from-purple-50 to-purple-100 p-4 rounded-xl hover:scale-105 transition-transform cursor-pointer">
                      <LineChart className="w-6 h-6 text-purple-600 mb-2" />
                      <div className="text-3xl font-bold text-gray-900">1.2M</div>
                      <div className="text-xs text-gray-600 font-medium">Data Points</div>
                    </div>
                  </div>

                  {/* Chart */}
                  <div className="bg-gradient-to-br from-blue-50 to-purple-50 rounded-xl p-4 h-32 flex items-end justify-between gap-2">
