# IoT Platform Backend Environment Configuration

# Application Environment
NODE_ENV=development
PORT=3001

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# AWS Configuration - REPLACE WITH YOUR REAL CREDENTIALS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here

# DynamoDB Table Names
USERS_TABLE=iot-platform-users
DEVICES_TABLE=iot-platform-devices
TELEMETRY_TABLE=iot-platform-telemetry
TEMPLATES_TABLE=iot-platform-templates
ALERTS_TABLE=iot-platform-alerts
ALERT_RULES_TABLE=iot-platform-alert-rules
INVITATIONS_TABLE=iot-platform-invitations
USER_DEVICE_PERMISSIONS_TABLE=iot-platform-user-device-permissions
DASHBOARD_LAYOUTS_TABLE=iot-platform-dashboard-layouts

# JWT Configuration - GENERATE SECURE SECRETS IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-change-in-production-make-it-very-long-and-random-minimum-32-chars
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Security Configuration
SESSION_SECRET=your-session-secret-here-minimum-32-characters-long-and-random
BCRYPT_ROUNDS=12

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_CORS_METHODS=GET,POST

# Optional: For production deployment
# AWS_PROFILE=default
# CORS_ORIGIN=https://yourdomain.com
# DATABASE_URL=postgresql://username:password@localhost:5432/iot_platform
# REDIS_URL=redis://localhost:6379
# EMAIL_SERVICE_API_KEY=your_email_service_key
# SMS_SERVICE_API_KEY=your_sms_service_key
